# Claude Code local state — can capture command history including credentials.
# Never commit this file.
.claude/settings.local.json

# Secrets
.env
.env.*
*.pem
*.key

# Generated artefacts. `python3 -m app.cli tower` writes here; the file is a
# render of live Jira at one instant, so it is reproducible and never a source.
out/

# Build / demo tooling
node_modules/
__pycache__/
.venv/
venv/
build/
dist/

# OS noise
.DS_Store
Thumbs.db

# React control tower build artifacts (bun install / bun run build recreate them)
webapp/node_modules/
webapp/dist/
webapp/.vite/
# Baked data is regenerated by the CI bake, so it stays out of git — EXCEPT the snapshot
# history, which must persist run-over-run (the bake appends to it and CI commits it back).
# Glob the contents (not the dir) so the negation below can re-include the history files.
webapp/public/data/*
!webapp/public/data/*-history.json
